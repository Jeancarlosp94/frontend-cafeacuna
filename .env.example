# ============================================
# VARIABLES DE ENTORNO - FRONTEND
# ============================================
# Copia este archivo como .env y configura tus valores
# Comando: cp .env.example .env
# ============================================

# ==========================================
# API BACKEND
# ==========================================
# URL del backend API
# ⚠️ Debe empezar con VITE_ para ser accesible en el código

# Desarrollo local
VITE_API_URL=http://localhost:5000/api

# Producción (ejemplo)
# VITE_API_URL=https://api.miapp.com/api

# ==========================================
# APLICACIÓN
# ==========================================
# Nombre de la aplicación
VITE_APP_NAME=CRM Empresarial

# Versión
VITE_APP_VERSION=1.0.0

# Ambiente
VITE_ENV=development

# ==========================================
# FEATURES (Activar/Desactivar)
# ==========================================
# Habilitar analytics (true/false)
VITE_ENABLE_ANALYTICS=false

# Habilitar monitoring con Sentry
VITE_ENABLE_SENTRY=false

# Habilitar logs de debug en consola
VITE_DEBUG_MODE=true

# ==========================================
# ANALYTICS (Opcional)
# ==========================================
# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=tu_token

# ==========================================
# MONITORING (Opcional)
# ==========================================
# Sentry DSN (para tracking de errores)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# LogRocket (para session replay)
# VITE_LOGROCKET_APP_ID=tu_app_id

# ==========================================
# MAPAS (Opcional)
# ==========================================
# Google Maps API Key
# VITE_GOOGLE_MAPS_API_KEY=tu_api_key

# Mapbox Token
# VITE_MAPBOX_TOKEN=tu_token

# ==========================================
# PAGOS (Opcional)
# ==========================================
# Stripe Publishable Key (para pagos)
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# ==========================================
# CHAT (Opcional)
# ==========================================
# Intercom App ID
# VITE_INTERCOM_APP_ID=tu_app_id

# Crisp Website ID
# VITE_CRISP_WEBSITE_ID=tu_website_id

# ==========================================
# CONFIGURACIÓN DE VITE
# ==========================================
# Puerto del dev server (opcional, por defecto 3000)
# VITE_PORT=3000

# Abrir navegador automáticamente
# VITE_OPEN_BROWSER=true

# ==========================================
# LÍMITES Y CONFIGURACIÓN
# ==========================================
# Tamaño máximo de archivos (MB)
VITE_MAX_FILE_SIZE=10

# Timeout de peticiones HTTP (ms)
VITE_REQUEST_TIMEOUT=30000

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 
# 1. TODAS las variables DEBEN empezar con VITE_
#    Si no, Vite no las incluirá en el build
#
# 2. Las variables son PÚBLICAS (se incluyen en el código del navegador)
#    ⚠️ NUNCA pongas secretos aquí (API keys privadas, passwords, etc.)
#
# 3. Este archivo NO debe subirse a Git
#    (ya está en .gitignore)
#
# 4. En producción (Vercel, Netlify):
#    - Configura las variables en el dashboard del hosting
#    - No uses archivos .env en producción
#
# 5. Para acceder en el código:
#    const apiUrl = import.meta.env.VITE_API_URL
#
# 6. Tipos de archivos .env:
#    .env                  # Todas las variables
#    .env.local           # Solo local (no se sube a Git)
#    .env.development     # Solo en desarrollo
#    .env.production      # Solo en producción
#
# ============================================
